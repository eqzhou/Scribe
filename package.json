{
  "name": "scribe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Scribe — A professional novel crafting system for writers worldwide.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:server": "npm --prefix server run build",
    "build:all": "npm run build && npm run build:server",
    "start": "node server/dist/index.js",
    "lint": "oxlint",
    "preview": "vite preview",
    "pm2:start": "npm run build:all && pm2 start ecosystem.config.cjs",
    "pm2:restart": "npm run build:all && pm2 restart scribe",
    "pm2:stop": "pm2 stop scribe",
    "pm2:logs": "pm2 logs scribe",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.5",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4",
    "turndown": "^7.2.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.2",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
